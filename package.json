{
	"name": "nudge",
	"version": "0.5.2",
	"description": "A task manager for Obsidian, backed by a single todo.txt file.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint main.ts src/",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
	"author": "2easy",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.5",
		"esbuild": "0.19.11",
		"eslint": "^9.39.5",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"obsidian": "latest",
		"tslib": "2.6.2",
		"typescript": "5.3.3",
		"typescript-eslint": "^8.64.0"
	},
	"dependencies": {
		"rrule": "^2.8.1"
	}
}
